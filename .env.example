# Path to the single local SQLite spine (ADR-0002). Defaults to ./data/vinyl.db
VINYL_DB_PATH=./data/vinyl.db

# OAuth token for the scheduled `claude -p` agent (ADR-0001).
# Produced by `claude setup-token` (Pro/Max subscription, not an API key).
# Do NOT pass --bare when invoking claude; it forces an API key.
CLAUDE_CODE_OAUTH_TOKEN=

# Discogs read-sync (issue #3). This is a single-user local app, so it uses a Discogs
# *personal access token* rather than 3-legged OAuth — the token is scoped to your own
# account, which is exactly what reading your own collection needs (no write scope).
# Generate one at https://www.discogs.com/settings/developers ("Generate new token").
# DISCOGS_USERNAME is the account whose collection is synced.
DISCOGS_USERNAME=
DISCOGS_TOKEN=
# Optional: override the User-Agent Discogs requires (defaults to VinylRoulette/0.1 ...).
DISCOGS_USER_AGENT=

# Cross-source pricing (issue #6). Looks up a chosen record on Discogs Marketplace AND Amazon
# and reports landed cost (item + shipping, GBP) per source; the picker buys from the cheaper.
# DISCOGS_TOKEN above is reused (optional for pricing — marketplace pages are public — but it
# lifts the search rate limit). Amazon needs no key; override the storefront for a non-UK locale.
AMAZON_BASE_URL=https://www.amazon.co.uk
