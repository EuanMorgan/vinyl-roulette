# Path to the single local SQLite spine (ADR-0002). Defaults to ./data/vinyl.db
VINYL_DB_PATH=./data/vinyl.db

# OAuth token for the scheduled `claude -p` agent (ADR-0001).
# Produced by `claude setup-token` (Pro/Max subscription, not an API key).
# Do NOT pass --bare when invoking claude; it forces an API key.
# scripts/run-agent.ps1 loads this from here into the scheduled Run's environment.
CLAUDE_CODE_OAUTH_TOKEN=

# Overrides the command that fires a Run (issue #11). Default: `npm run agent:run`. Set this to
# the real Brain invocation once it ships, e.g. `claude -p prompt.md` — the "Run now" button and
# the Windows Task Scheduler job both pick it up, and the --trigger/--if-due flags are appended
# automatically. Never include --bare (ADR-0001: it forces a metered API key over the OAuth token).
VINYL_AGENT_CMD=

# Discogs read-sync (issue #3). This is a single-user local app, so it uses a Discogs
# *personal access token* rather than 3-legged OAuth — the token is scoped to your own
# account, which is exactly what reading your own collection needs (no write scope).
# Generate one at https://www.discogs.com/settings/developers ("Generate new token").
# DISCOGS_USERNAME is the account whose collection is synced.
DISCOGS_USERNAME=
DISCOGS_TOKEN=
# Optional: override the User-Agent Discogs requires (defaults to VinylRoulette/0.1 ...).
DISCOGS_USER_AGENT=

# Cross-source pricing (issue #6). Looks up a chosen record on Discogs Marketplace AND Amazon
# and reports landed cost (item + shipping, GBP) per source; the picker buys from the cheaper.
# DISCOGS_TOKEN above is reused (optional for pricing — marketplace pages are public — but it
# lifts the search rate limit). Amazon needs no key; override the storefront for a non-UK locale.
AMAZON_BASE_URL=https://www.amazon.co.uk

# The Playwright buy (issue #9). At approval, Playwright drives your REAL Chrome profile so it
# reuses your logged-in Amazon/Discogs/PayPal sessions and you clear any 2FA/PayPal/CVV yourself
# (ADR-0003 — local only, never deployed). CHROME_USER_DATA_DIR must point at your real Chrome
# user-data dir; without it the Approve button is a no-op. CHROME_CHANNEL overrides the launched
# channel (defaults to "chrome" — the installed system Chrome, so no browser download is needed).
# Tip: close Chrome before approving — a running Chrome holds a lock on the profile.
# Windows default: C:\Users\<you>\AppData\Local\Google\Chrome\User Data
CHROME_USER_DATA_DIR=
CHROME_CHANNEL=chrome
