# Path to the single local SQLite spine (ADR-0002). Defaults to ./data/vinyl.db
VINYL_DB_PATH=./data/vinyl.db

# OAuth token for the scheduled `claude -p` agent (ADR-0001).
# Produced by `claude setup-token` (Pro/Max subscription, not an API key).
# Do NOT pass --bare when invoking claude; it forces an API key.
CLAUDE_CODE_OAUTH_TOKEN=
